VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Strava OAuth — get from https://www.strava.com/settings/api
# The Client Secret is server-side only (Cloud Function) — never expose it here.
VITE_STRAVA_CLIENT_ID=

# Fitbit OAuth — get from https://dev.fitbit.com/apps
VITE_FITBIT_CLIENT_ID=
VITE_FITBIT_CLIENT_SECRET=
# Optional: override the redirect URI (defaults to {origin}/exchange_token)
# VITE_FITBIT_REDIRECT_URI=
